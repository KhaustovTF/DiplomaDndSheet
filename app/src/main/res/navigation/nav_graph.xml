<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/charListFragment">

    <fragment
        android:id="@+id/charListFragment"
        android:name="ru.learning.rpgcompanionapp.fragments.CharListFragment"
        android:label="fragment_char_list"
        tools:layout="@layout/fragment_char_list" >
        <action
            android:id="@+id/action_charListFragment_to_charEditFragment"
            app:destination="@id/charEditFragment" />
        <action
            android:id="@+id/action_charListFragment_to_characterFragment"
            app:destination="@id/characterFragment" />
    </fragment>
    <fragment
        android:id="@+id/charEditFragment"
        android:name="ru.learning.rpgcompanionapp.fragments.CharEditFragment"
        android:label="fragment_char_edit"
        tools:layout="@layout/fragment_char_edit" />
    <fragment
        android:id="@+id/characterFragment"
        android:name="ru.learning.rpgcompanionapp.fragments.CharacterFragment"
        android:label="fragment_character"
        tools:layout="@layout/fragment_character" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="ru.learning.rpgcompanionapp.fragments.SettingsFragment"
        android:label="@string/settings_title" />

</navigation>